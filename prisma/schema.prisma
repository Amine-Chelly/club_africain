generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Sport {
  FOOTBALL
  HANDBALL
  BASKETBALL
  VOLLEYBALL
  TENNIS
  OTHER
}

enum MerchType {
  JERSEY
  SHORTS
  SCARF
  SOCKS
  SWEATSHIRT
  OTHER
}

enum TeamCategory {
  TEAM_SPORT
  INDIVIDUAL
}

enum AgeGroup {
  U8
  U11
  U13
  U15
  U17
  U19
  U21
  U23
  SENIOR
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

enum OrderPaymentType {
  CASH
  CARD
  BANK_TRANSFER
}

enum OrderDeliveryType {
  PICKUP
  DELIVERY
}

enum TennisTournamentCategory {
  ITF
  ATP
  WTA
}

enum TournamentTier {
  GRAND_SLAM
  STANDARD
}

enum AthleteGender {
  MALE
  FEMALE
}

enum TeamGender {
  MALE
  FEMALE
}

enum FixturePlayerEventType {
  APPEARANCE
  GOAL
  POINT
}

enum FixtureStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELED
}

enum MatchdayType {
  LEAGUE
  CUP
  TOURNAMENT
}

enum SubscriptionType {
  VIRAGE
  PELOUSE
  ENCEINTE_SUP
  ENCEINTE_INF
  TRIBUNE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          Role      @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  cart          Cart?
  subscriptions SeasonSubscription[]
  passwordResetTokens PasswordResetToken[]
}

model Team {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  sport       Sport
  gender      TeamGender   @default(MALE)
  category    TeamCategory
  ageGroup    AgeGroup
  imageUrl    String?
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  players     Player[]
  staff       Staff[]
  fixtures    Fixture[]
}

model Player {
  id          String  @id @default(cuid())
  teamId      String
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  number      Int?
  position    String?
  nationality String?
  isActive    Boolean @default(true)
  appearances Int     @default(0)
  goals       Int     @default(0)
  ranking     Int?
  singlesRanking Int?
  doublesRanking Int?
  imageUrl    String?
  gender      AthleteGender?
  fixtures    Fixture[]
  fixtureStats FixturePlayerStat[]
  fixtureEvents FixturePlayerEvent[]
}

model Staff {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name   String
  role   String
  imageUrl String?
}

model Fixture {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId    String?
  player      Player?  @relation(fields: [playerId], references: [id], onDelete: SetNull)
  kickoffAt   DateTime
  matchdayId  String?
  matchday    Matchday? @relation(fields: [matchdayId], references: [id], onDelete: Cascade)
  opponent    String
  venue       String
  isHome      Boolean  @default(true)
  homeScore   Int?
  awayScore   Int?
  competition String
  imageUrl    String?
  status      FixtureStatus @default(SCHEDULED)

  @@index([playerId])
  playerStats FixturePlayerStat[]
  events FixturePlayerEvent[]
}



model FixturePlayerStat {
  id        String @id @default(cuid())
  fixtureId String
  fixture   Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  count     Int     @default(0)

  @@unique([fixtureId, playerId])
  @@index([playerId])
}

model FixturePlayerEvent {
  id        String @id @default(cuid())
  fixtureId String
  fixture   Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  type      FixturePlayerEventType

  @@index([fixtureId])
  @@index([playerId])
  @@index([type])
}

model Matchday {
  id        String   @id @default(cuid())
  label     String
  season    String?
  sport     Sport?
  type      MatchdayType @default(LEAGUE)
  imageUrl  String?
  
  tennisCategory TennisTournamentCategory?
  tournamentTier TournamentTier?

  fixtures  Fixture[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sport])
  @@index([season])
  @@index([type])
  @@unique([label, season, sport])
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  priceCents  Int
  category    String
  merchType   MerchType   @default(OTHER)
  sport       Sport?
  sizeOptions String[]    @default([])
  imageUrl    String?     // legacy single image; new images live in ProductImage
  stock       Int         @default(0) // legacy aggregate stock; per-size stock lives in ProductSizeStock
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  cartItems   CartItem[]
  sizeStocks  ProductSizeStock[]
  images      ProductImage[]
}

model ProductSizeStock {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  /**
   * Size identifier; must be present in Product.sizeOptions for selectable sizes.
   * Keep rows even when stock is 0 so admin can refill later.
   */
  sizeOption String
  stock      Int     @default(0)

  @@unique([productId, sizeOption])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  /**
   * Lower sortOrder means earlier in galleries; cover image is the first by sortOrder.
   */
  sortOrder Int     @default(0)
  isCover   Boolean @default(false)

  @@index([productId, sortOrder])
  @@unique([productId, sortOrder])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?    @unique
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id         String  @id @default(cuid())
  cartId     String
  cart       Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Int     @default(1)
  /**
   * Selected size at add-to-cart time. Empty string = "no size".
   */
  sizeOption String  @default("")

  @@unique([cartId, productId, sizeOption])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                OrderStatus @default(PENDING)
  paymentType           OrderPaymentType @default(CASH)
  deliveryType          OrderDeliveryType @default(PICKUP)
  validatedAt           DateTime?
  totalCents            Int
  stripePaymentIntentId String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  items                 OrderItem[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  priceCents Int
  sizeOption String  @default("")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("fr")
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  level     String
  action    String
  userId    String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())
}

/// Rich-text history block for a sport section on the /club page.
model ClubSportHistory {
  id        String   @id @default(cuid())
  sport     Sport    @unique
  body      String   // multi-paragraph HTML/markdown allowed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A single palmarès (title) entry for a sport.
model ClubTitle {
  id          String   @id @default(cuid())
  sport       Sport
  competition String   // e.g. "Championnat de Tunisie"
  year        Int
  detail      String?  // e.g. "Vice-champion", extra notes
  imageUrl    String?  // optional trophy / celebration image
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([sport, sortOrder])
}

/// A venue / stadium associated with a sport section.
model ClubVenue {
  id        String            @id @default(cuid())
  sport     Sport             @unique
  name      String
  city      String
  capacity  Int?
  imageUrl  String?
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  images    ClubVenueImage[]
}

/// An individual image belonging to a ClubVenue gallery.
model ClubVenueImage {
  id        String    @id @default(cuid())
  venueId   String
  venue     ClubVenue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int       @default(0)
  isCover   Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([venueId, sortOrder])
}

model SeasonSubscription {
  id          String           @id @default(cuid())
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  season      String           @default("2025/2026")
  fullName    String
  birthDate   DateTime
  seatType              SubscriptionType
  priceCents            Int
  status                OrderStatus      @default(PENDING)
  paymentType           OrderPaymentType @default(CASH)
  stripePaymentIntentId String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}
