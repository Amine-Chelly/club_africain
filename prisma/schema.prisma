generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Sport {
  FOOTBALL
  HANDBALL
  BASKETBALL
  VOLLEYBALL
  TENNIS
  OTHER
}

enum MerchType {
  JERSEY
  SHORTS
  SCARF
  SOCKS
  SWEATSHIRT
  OTHER
}

enum TeamCategory {
  TEAM_SPORT
  INDIVIDUAL
}

enum AgeGroup {
  U8
  U11
  U13
  U15
  U17
  U19
  U21
  U23
  SENIOR
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          Role      @default(USER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
  cart          Cart?
}

model Team {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  sport       Sport
  category    TeamCategory
  ageGroup    AgeGroup
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  players     Player[]
  staff       Staff[]
  fixtures    Fixture[]
}

model Player {
  id          String  @id @default(cuid())
  teamId      String
  team        Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  number      Int?
  position    String?
  nationality String?
  appearances Int     @default(0)
  goals       Int     @default(0)
}

model Staff {
  id     String @id @default(cuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name   String
  role   String
}

model Fixture {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  kickoffAt   DateTime
  matchdayId  String?
  matchday    Matchday? @relation(fields: [matchdayId], references: [id], onDelete: Cascade)
  opponent    String
  venue       String
  isHome      Boolean  @default(true)
  homeScore   Int?
  awayScore   Int?
  competition String
  status      String   @default("SCHEDULED")
}

model Matchday {
  id        String   @id @default(cuid())
  label     String
  season    String?
  sport     Sport?
  fixtures  Fixture[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sport])
  @@index([season])
  @@unique([label, season, sport])
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  priceCents  Int
  category    String
  merchType   MerchType   @default(OTHER)
  sport       Sport?
  sizeOptions String[]    @default([])
  imageUrl    String?     // legacy single image; new images live in ProductImage
  stock       Int         @default(0) // legacy aggregate stock; per-size stock lives in ProductSizeStock
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  cartItems   CartItem[]
  sizeStocks  ProductSizeStock[]
  images      ProductImage[]
}

model ProductSizeStock {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  /**
   * Size identifier; must be present in Product.sizeOptions for selectable sizes.
   * Keep rows even when stock is 0 so admin can refill later.
   */
  sizeOption String
  stock      Int     @default(0)

  @@unique([productId, sizeOption])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  /**
   * Lower sortOrder means earlier in galleries; cover image is the first by sortOrder.
   */
  sortOrder Int     @default(0)
  isCover   Boolean @default(false)

  @@index([productId, sortOrder])
  @@unique([productId, sortOrder])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String?    @unique
  items     CartItem[]
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id         String  @id @default(cuid())
  cartId     String
  cart       Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity   Int     @default(1)
  /**
   * Selected size at add-to-cart time. Empty string = "no size".
   */
  sizeOption String  @default("")

  @@unique([cartId, productId, sizeOption])
}

model Order {
  id                    String      @id @default(cuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                OrderStatus @default(PENDING)
  totalCents            Int
  stripePaymentIntentId String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  items                 OrderItem[]
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  priceCents Int
  sizeOption String  @default("")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("fr")
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  level     String
  action    String
  userId    String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())
}
